@article{xiao2022sciadv,
  title={ETS1 acts as a regulator of human healthy aging via decreasing ribosomal activity},
  author={Xiao, F. H. and Yu, Q. and Deng, Z. L. and others and Li, J. and Kong, Q. P.},
  journal={Science Advances},
  year={2022},
  doi={10.1126/sciadv.abf2017},
  preview={xiao2022sciadv.jpg},
  pmid={35476452},
  selected={true},
  bibtex_show={true},
  abstract={We analyzed transcriptomes of 185 long-lived individuals (LLIs) and 86 spouses of their children from two independent Chinese longevity cohorts and found that the ribosome pathway was significantly down-regulated in LLIs. The down-regulation is likely controlled by ETS1, a transcription factor down-regulated in LLIs and positively coexpressed with most ribosomal protein genes. Functional assays showed that ETS1 knockdown reduces ribosomal protein gene expression and alleviates cellular senescence. The decline in ribosomal biogenesis governed by ETS1 in certain female LLIs may serve as an alternative mechanism to achieve energy-saving and healthy aging.},
  category={skin_aging}
}

