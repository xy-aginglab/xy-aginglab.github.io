}

@article{rao2022frontmedlau,
  title={Mammary Paget Disease With Melanocytic Proliferation Mimicking Malignant Melanoma in situ: A Case Report},
  author={Rao, S. and Wang, A. and Liu, W. and Yin, H. and Li, J. and Tsang, L. S. and Wu, Y. and Shi, W.},
  first_author={S. Rao},
  corresponding_author={Yuhui Wu; Wei Shi},
  journal={Frontiers in medicine},
  year={2022},
  doi={10.3389/fmed.2022.839954},
  volume={9},
  pages={839954},
  pmid={35386919},
  abstract={Several cases of pigmented mammary Paget's disease (PMPD) mimicking cutaneous malignant melanoma have been reported. In these cases, the tumor cells are colonized by melanocytes, particularly with the presence of a population of melanocytes staining for HMB-45 and S100. Here, we report a case of mammary Paget disease (MPD) which was misdiagnosed as melanoma in situ due to the interpretation of the staining of melanocytic markers S-100, Melan-A, and HMB-45. The tumor cells strongly expressed CK7 and GATA3, and a dual-labeling showed negative PHH3 labeling for the melanocytes. Pathologists need to be aware of the caveat of colonization of melanocytes in Paget disease.},
