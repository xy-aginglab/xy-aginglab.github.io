@article{zhao2024redoxbiol,
  title={Twin defect-rich Pt ultrathin nanowire nanozymes alleviate inflammatory skin diseases by scavenging reactive oxygen species},
  author={Zhao, H. and Zhao, H. and Li, M. and Tang, Y. and Xiao, X. and Cai, Y. and He, F. and Huang, H. and Zhang, Y. and Li, J.},
