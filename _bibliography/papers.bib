@article{zhu2022frontcelldevbiol,
  title={Neuroimmune Interaction: A Widespread Mutual Regulation and the Weapons for Barrier Organs},
  author={Zhu, Y. and Duan, S. and Wang, M. and Deng, Z. and Li, J.},
  first_author={Yan Zhu; Shixin Duan; Mei Wang},
  corresponding_author={Zhili Deng; Ji Li},
  journal={Frontiers in cell and developmental biology},
  year={2022},
  doi={10.3389/fcell.2022.906755},
  volume={10},
  pages={906755},
  pmid={35646918},
  abstract={Since the embryo, the nervous system and immune system have been interacting to regulate each other's development and working together to resist harmful stimuli. However, oversensitive neural response and uncontrolled immune attack are major causes of various diseases, especially in barrier organs, while neural-immune interaction makes it worse. As the first defense line, the barrier organs give a guarantee to maintain homeostasis in external environment. And the dense nerve innervation and abundant immune cell population in barrier organs facilitate the neuroimmune interaction, which is the physiological basis of multiple neuroimmune-related diseases. Neuroimmune-related diseases often have complex mechanisms and require a combination of drugs, posing challenges in finding etiology and treatment. Therefore, it is of great significance to illustrate the specific mechanism and exact way of neuro-immune interaction. In this review, we first described the mutual regulation of the two principal systems and then focused on neuro-immune interaction in the barrier organs, including intestinal tract, lungs and skin, to clarify the mechanisms and provide ideas for clinical etiology exploration and treatment.},
  category={pilosebaceous},
  subcategory={rosacea},
  impact_factor={5.5},
  jcr_quartile={Q2},
  publication_type={review},
  language={en},
  basic={true},
