@article{li2020jdermatol_epi,
  title={Epidemiological features of rosacea in Changsha, China: A population-based, cross-sectional study},
  author={Li, J. and Wang, B. and Deng, Y. and Shi, W. and Jian, D. and Liu, F. and Huang, Y. and Tang, Y. and Zhao, Z. and Huang, X. and Li, J. and Xie, H.},
