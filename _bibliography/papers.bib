@article{chen2024natcommun_rosacea,
  title={Single-cell transcriptomics reveals aberrant skin cells and fibroblasts in rosacea},
  author={Chen, M. and Yang, L. and Zhou, P. and Jin, S. and Wu, Z. and Tan, Z. and Xiao, W. and Xu, S. and Zhu, Y. and Wang, M. and Jian, D. and Liu, F. and Tang, Y. and Zhao, Z. and Huang, Y. and Shi, W. and Xie, H. and Nie, Q. and Wang, B. and Deng, Z. and Li, J.},
  journal={Nature Communications},
  year={2024},
  doi={10.1038/s41467-024-52946-7},
  preview={chen2024natcommun_rosacea.jpg},
  pmid={39384741},


  selected={true},
  bibtex_show={true},
  abstract={Rosacea is a chronic inflammatory skin disorder, whose underlying cellular and molecular mechanisms remain obscure. Here, we generate a single-cell atlas of facial skin from female rosacea patients and healthy individuals. Among keratinocytes, a subpopulation characterized by IFN-gamma-mediated barrier function damage is found to be unique to rosacea lesions. The papulopustular rosacea is featured by expansion of pro-inflammatory fibroblasts, Schwann, endothelial and macrophage/dendritic cells. Most importantly, fibroblasts are identified as the leading cell type producing pro-inflammatory and vasodilative signals in rosacea. Depletion of fibroblasts or knockdown of PTGDS blocks rosacea development in mice.},
  category={inflammatory_skin}
}

@article{zhang2024natcommun_sensory,
  title={High-sensitive sensory neurons exacerbate rosacea-like dermatitis by activating gamma-delta T cells},
  author={Zhang, Y. and Li, T. and Zhao, H. and Xiao, X. and Hu, X. and Wang, B. and Huang, Y. and Yin, Z. and Zhong, Y. and Li, Y. and Li, J.},
  journal={Nature Communications},
  year={2024},
  doi={10.1038/s41467-024-50970-1},
  preview={zhang2024natcommun_sensory.jpg},
  pmid={39179539},


  selected={true},
  bibtex_show={true},
  abstract={Rosacea patients show facial hypersensitivity to stimulus factors; however, the underlying mechanism remains poorly defined. Here, we show capsaicin stimulation in mice induces exacerbated rosacea-like dermatitis. We find that gamma-delta T cells express Ramp1, the receptor of the neuropeptide CGRP, and are significantly increased in rosacea skin lesions. CGRP induces IL17A secretion from gamma-delta T cells by regulating inflammation-related and metabolism-related pathways. Rimegepant, a CGRP receptor antagonist, shows efficacy in the treatment of rosacea-like dermatitis. Our findings demonstrate a neuron-CGRP-gamma-delta-T cell axis that contributes to the hyperresponsiveness of rosacea.},
  category={inflammatory_skin}
}

