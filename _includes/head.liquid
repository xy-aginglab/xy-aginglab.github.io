<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% if page.title %}{{ page.title }} | {% endif %}{{ site.title }}</title>
<meta name="description" content="{{ page.description | default: site.description | strip_html | truncatewords: 50 }}">
<link rel="canonical" href="{{ page.url | replace:'index.html','' | absolute_url }}">

<!-- OpenGraph -->
<meta property="og:title" content="{{ page.title | default: site.title }}">
<meta property="og:description" content="{{ page.description | default: site.description | strip_html | truncatewords: 50 }}">
<meta property="og:type" content="website">
<meta property="og:url" content="{{ page.url | absolute_url }}">

<!-- Favicon -->
{% if site.icon %}
{% assign icon_value = site.icon | strip %}
{% if icon_value contains '://' %}
  {% assign favicon_href = icon_value %}
{% elsif icon_value contains '/' or icon_value contains '.' %}
  {% assign favicon_href = icon_value | relative_url %}
{% else %}
  {% capture emoji_svg %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><text y=".9em" font-size="90">{{ icon_value }}</text></svg>{% endcapture %}
  {% assign emoji_svg_escaped = emoji_svg | uri_escape %}
  {% assign favicon_href = 'data:image/svg+xml,' | append: emoji_svg_escaped %}
{% endif %}
<link rel="icon" href="{{ favicon_href }}">
{% endif %}

<!-- Google Fonts: Inter -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap">

<!-- Styles -->
<link rel="stylesheet" href="{{ '/assets/css/main.css' | relative_url }}">

<!-- Academic icons -->
<link rel="stylesheet" href="{{ '/assets/css/academicons.min.css' | relative_url }}">
<link rel="stylesheet" href="{{ '/assets/css/scholar-icons.css' | relative_url }}">

<!-- Code highlighting -->
<link rel="stylesheet" href="{{ '/assets/css/jekyll-pygments-themes-github.css' | relative_url }}" id="highlight-theme-light">
<link rel="stylesheet" href="{{ '/assets/css/jekyll-pygments-themes-native.css' | relative_url }}" id="highlight-theme-dark" disabled>

<!-- Dark mode (must be in head to avoid flash) -->
{% if site.enable_darkmode %}
<script src="{{ '/assets/js/theme.js' | relative_url }}"></script>
{% endif %}

<!-- RSS -->
{% feed_meta %}
