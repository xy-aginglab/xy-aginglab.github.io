{% assign lang = page.lang | default: 'en' %}
{% if lang == 'zh' and project.title_zh %}
  {% assign p_title = project.title_zh %}
{% else %}
  {% assign p_title = project.title %}
{% endif %}
{% if lang == 'zh' and project.description_zh %}
  {% assign p_desc = project.description_zh %}
{% else %}
  {% assign p_desc = project.description %}
{% endif %}
{% if project.redirect %}
  {% assign project_href = project.redirect %}
{% elsif lang == 'zh' %}
  {% assign project_slug = project.title | slugify %}
  {% assign project_href = '/v1/zh/projects/' | append: project_slug | append: '/' | relative_url %}
{% else %}
  {% assign project_href = project.url | relative_url %}
{% endif %}
<a href="{{ project_href }}" class="lab-project-card-link">
  <div class="card hoverable">
    {% if project.img %}
      <img src="{{ project.img | prepend: '/assets/img/' | relative_url }}" alt="{{ p_title }}" class="card-img-top" loading="eager">
    {% endif %}
    <div class="card-body">
      <h2 class="card-title">{{ p_title }}</h2>
      <p class="card-text">{{ p_desc }}</p>
    </div>
  </div>
</a>
