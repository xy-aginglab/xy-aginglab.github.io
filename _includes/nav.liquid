{% assign current_url = page.url | default: '' %}
{% assign lang = page.lang | default: 'en' %}
<header class="v2-topbar">
  <div class="v2-topbar__inner">
    {% if lang == 'zh' %}
    <a class="v2-topbar__brand" href="{{ '/zh/' | relative_url }}" translate="no">Li Lab</a>
    {% else %}
    <a class="v2-topbar__brand" href="{{ '/' | relative_url }}" translate="no">Li Lab</a>
    {% endif %}
    <button class="v2-topbar__toggle" aria-label="Toggle navigation" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <nav class="v2-topbar__nav">
      {% if lang == 'zh' %}
      <a href="{{ '/zh/' | relative_url }}"{% if current_url == '/zh/' %} class="is-active"{% endif %}>首页</a>
      <a href="{{ '/zh/research/' | relative_url }}"{% if current_url contains '/zh/research' %} class="is-active"{% endif %}>研究方向</a>
      <a href="{{ '/zh/publications/' | relative_url }}"{% if current_url contains '/zh/publications' %} class="is-active"{% endif %}>论文发表</a>
      <a href="{{ '/zh/people/' | relative_url }}"{% if current_url contains '/zh/people' %} class="is-active"{% endif %}>团队成员</a>
      <a href="{{ '/zh/clinical/' | relative_url }}"{% if current_url contains '/zh/clinical' %} class="is-active"{% endif %}>临床研究</a>
      <a href="{{ '/zh/contact/' | relative_url }}"{% if current_url contains '/zh/contact' %} class="is-active"{% endif %}>联系我们</a>
      <a href="{{ '/' | relative_url }}">English</a>
      {% else %}
      <a href="{{ '/' | relative_url }}"{% if current_url == '/' %} class="is-active"{% endif %}>Home</a>
      <a href="{{ '/research/' | relative_url }}"{% if current_url contains '/research' %} class="is-active"{% endif %}>Research</a>
      <a href="{{ '/publications/' | relative_url }}"{% if current_url contains '/publications' or current_url contains '/bibliography/' %} class="is-active"{% endif %}>Publications</a>
      <a href="{{ '/people/' | relative_url }}"{% if current_url contains '/people' %} class="is-active"{% endif %}>People</a>
      <a href="{{ '/clinical/' | relative_url }}"{% if current_url contains '/clinical' %} class="is-active"{% endif %}>Clinical</a>
      <a href="{{ '/contact/' | relative_url }}"{% if current_url contains '/contact' %} class="is-active"{% endif %}>Contact</a>
      <a href="{{ '/zh/' | relative_url }}">中文</a>
      {% endif %}
    </nav>
  </div>
</header>
