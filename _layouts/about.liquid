---
layout: default
---

<!-- Hero Section -->
<div class="lab-hero">
  <div class="lab-hero__inner">
    <h1 class="lab-hero__title">{{ site.title }}</h1>
    <p class="lab-hero__subtitle">{{ page.subtitle }}</p>
    <div class="lab-hero__divider"></div>
    <p class="lab-hero__tagline">{{ page.tagline }}</p>
  </div>
</div>

<!-- About Section -->
<div class="lab-section">
  <div class="lab-about">
    {{ content }}
  </div>
</div>

<!-- Research Directions -->
{% if page.research_areas %}
<div class="lab-section lab-section--alt">
  <h2 class="lab-section__heading">Research Directions</h2>
  <div class="lab-research-grid">
    {% for area in page.research_areas %}
    <div class="lab-research-card">
      <div class="lab-research-card__icon">
        <i class="fas {{ area.icon }}"></i>
      </div>
      <h3 class="lab-research-card__title">{{ area.title }}</h3>
      <p class="lab-research-card__desc">{{ area.description }}</p>
      {% if area.link %}
        <a href="{{ area.link | relative_url }}" class="lab-research-card__link">
          Learn more <i class="fas fa-arrow-right"></i>
        </a>
      {% endif %}
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

<!-- Selected Papers -->
{% if page.selected_papers %}
<div class="lab-section">
  <h2 class="lab-section__heading">
    <a href="{{ '/publications/' | relative_url }}" style="color: inherit; text-decoration: none">
      Selected Publications
    </a>
  </h2>
  {% include selected_papers.liquid %}
</div>
{% endif %}

<!-- Contact / Social -->
{% if page.social %}
<div class="lab-section lab-section--alt">
  <h2 class="lab-section__heading">Contact</h2>
  <div class="lab-contact">
    {% if page.profile and page.profile.more_info %}
      <div class="lab-contact__info">{{ page.profile.more_info }}</div>
    {% endif %}
    <div class="lab-contact__icons">
      {% social_links %}
    </div>
  </div>
</div>
{% endif %}
