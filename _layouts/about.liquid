---
layout: default
---
{% assign lang = page.lang | default: 'en' %}
{% assign t = site.data.i18n[lang] %}

<!-- Hero Section -->
<div class="lab-hero">
  <div class="lab-hero__inner">
    <h1 class="lab-hero__title">
      {% if lang == 'zh' %}衰老生物学湖南省重点实验室{% else %}{{ site.title }}{% endif %}
    </h1>
    <p class="lab-hero__subtitle">{{ t.hero.subtitle }}</p>
    <div class="lab-hero__divider"></div>
    <p class="lab-hero__tagline">{{ t.hero.tagline }}</p>
  </div>
</div>

<!-- About Section -->
<div class="lab-section">
  <div class="lab-about">
    {{ t.home.about_body | markdownify }}
  </div>
</div>

<!-- Research Directions -->
<div class="lab-section lab-section--alt">
  <h2 class="lab-section__heading">{{ t.home.research_heading }}</h2>
  <div class="lab-research-grid">
    <div class="lab-research-card">
      <div class="lab-research-card__icon">
        <i class="fas fa-dna"></i>
      </div>
      <h3 class="lab-research-card__title">{{ t.research.skin_aging_title }}</h3>
      <p class="lab-research-card__desc">{{ t.research.skin_aging_desc }}</p>
      {% if lang == 'zh' %}
        <a href="{{ '/zh/projects/' | relative_url }}" class="lab-research-card__link">
          {{- t.home.learn_more }}
          <i class="fas fa-arrow-right"></i
        ></a>
      {% else %}
        <a href="{{ '/projects/' | relative_url }}" class="lab-research-card__link">
          {{- t.home.learn_more }}
          <i class="fas fa-arrow-right"></i
        ></a>
      {% endif %}
    </div>
    <div class="lab-research-card">
      <div class="lab-research-card__icon">
        <i class="fas fa-microscope"></i>
      </div>
      <h3 class="lab-research-card__title">{{ t.research.hair_follicle_title }}</h3>
      <p class="lab-research-card__desc">{{ t.research.hair_follicle_desc }}</p>
      {% if lang == 'zh' %}
        <a href="{{ '/zh/projects/' | relative_url }}" class="lab-research-card__link">
          {{- t.home.learn_more }}
          <i class="fas fa-arrow-right"></i
        ></a>
      {% else %}
        <a href="{{ '/projects/' | relative_url }}" class="lab-research-card__link">
          {{- t.home.learn_more }}
          <i class="fas fa-arrow-right"></i
        ></a>
      {% endif %}
    </div>
    <div class="lab-research-card">
      <div class="lab-research-card__icon">
        <i class="fas fa-shield-virus"></i>
      </div>
      <h3 class="lab-research-card__title">{{ t.research.inflammatory_title }}</h3>
      <p class="lab-research-card__desc">{{ t.research.inflammatory_desc }}</p>
      {% if lang == 'zh' %}
        <a href="{{ '/zh/projects/' | relative_url }}" class="lab-research-card__link">
          {{- t.home.learn_more }}
          <i class="fas fa-arrow-right"></i
        ></a>
      {% else %}
        <a href="{{ '/projects/' | relative_url }}" class="lab-research-card__link">
          {{- t.home.learn_more }}
          <i class="fas fa-arrow-right"></i
        ></a>
      {% endif %}
    </div>
  </div>
</div>

<!-- Selected Papers -->
{% if page.selected_papers %}
  <div class="lab-section">
    <h2 class="lab-section__heading">
      {% if lang == 'zh' %}
        <a href="{{ '/zh/publications/' | relative_url }}" style="color: inherit; text-decoration: none">{{ t.home.selected_pubs_heading }}</a>
      {% else %}
        <a href="{{ '/publications/' | relative_url }}" style="color: inherit; text-decoration: none">{{ t.home.selected_pubs_heading }}</a>
      {% endif %}
    </h2>
    {% include selected_papers.liquid %}
  </div>
{% endif %}

<!-- Contact / Social -->
{% if page.social %}
  <div class="lab-section lab-section--alt">
    <h2 class="lab-section__heading">{{ t.home.contact_heading }}</h2>
    <div class="lab-contact">
      <div class="lab-contact__info">
        <p>{{ t.home.address_line1 }}</p>
        <p>{{ t.home.address_line2 }}</p>
        <p>{{ t.home.address_line3 }}</p>
      </div>
      <div class="lab-contact__icons">
        {% if site.data.socials.email %}
          <a href="mailto:{{ site.data.socials.email }}" title="Email"><i class="fas fa-envelope"></i></a>
        {% endif %}
        {% if site.data.socials.github %}
          <a href="https://github.com/{{ site.data.socials.github }}" target="_blank" title="GitHub"><i class="fab fa-github"></i></a>
        {% endif %}
        {% if site.data.socials.scholar_userid %}
          <a href="https://scholar.google.com/citations?user={{ site.data.socials.scholar_userid }}" target="_blank" title="Google Scholar"
            ><i class="ai ai-google-scholar"></i
          ></a>
        {% endif %}
        {% if site.data.socials.orcid %}
          <a href="https://orcid.org/{{ site.data.socials.orcid }}" target="_blank" title="ORCID"><i class="ai ai-orcid"></i></a>
        {% endif %}
      </div>
    </div>
  </div>
{% endif %}
