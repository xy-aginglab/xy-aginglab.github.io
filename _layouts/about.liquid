---
layout: default
---
{% assign lang = page.lang | default: 'en' %}
{% assign t = site.data.i18n[lang] %}

<!-- Hero Section -->
<div class="lab-hero">
  <div class="lab-hero__inner">
    <h1 class="lab-hero__title">
      {% if lang == 'zh' %}衰老生物学湖南省重点实验室{% else %}{{ site.title }}{% endif %}
    </h1>
    <p class="lab-hero__subtitle">{{ t.hero.subtitle }}</p>
    <div class="lab-hero__divider"></div>
    <p class="lab-hero__tagline">{{ t.hero.tagline }}</p>
  </div>
</div>

<!-- Research Directions -->
<div class="lab-section lab-section--alt">
  <h2 class="lab-section__heading">{{ t.home.research_heading }}</h2>
  <div class="lab-research-grid">
    <div class="lab-research-card">
      <div class="lab-research-card__banner">
        <img src="{{ '/assets/img/research_hair_follicle.svg' | relative_url }}" alt="Pilosebaceous Unit Diseases">
      </div>
      <div class="lab-research-card__content">
        <h3 class="lab-research-card__title">{{ t.research.pilosebaceous_title }}</h3>
        <p class="lab-research-card__desc">{{ t.research.pilosebaceous_desc }}</p>
        <a
          href="{% if lang == 'zh' %}{{ '/v1/zh/projects/' | relative_url }}{% else %}{{ '/v1/projects/' | relative_url }}{% endif %}"
          class="lab-research-card__link"
        >
          {{- t.home.learn_more }}
          <i class="fas fa-arrow-right"></i>
        </a>
      </div>
    </div>
    <div class="lab-research-card">
      <div class="lab-research-card__banner">
        <img src="{{ '/assets/img/research_skin_aging.svg' | relative_url }}" alt="Skin Aging">
      </div>
      <div class="lab-research-card__content">
        <h3 class="lab-research-card__title">{{ t.research.skin_aging_title }}</h3>
        <p class="lab-research-card__desc">{{ t.research.skin_aging_desc }}</p>
        <a
          href="{% if lang == 'zh' %}{{ '/v1/zh/projects/' | relative_url }}{% else %}{{ '/v1/projects/' | relative_url }}{% endif %}"
          class="lab-research-card__link"
        >
          {{- t.home.learn_more }}
          <i class="fas fa-arrow-right"></i>
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Selected Papers -->
{% if page.selected_papers %}
  <div class="lab-section">
    <h2 class="lab-section__heading">
      <a
        href="{% if lang == 'zh' %}{{ '/v1/zh/publications/' | relative_url }}{% else %}{{ '/v1/publications/' | relative_url }}{% endif %}"
        style="color: inherit; text-decoration: none"
      >
        {{- t.home.selected_pubs_heading -}}
      </a>
    </h2>
    {% include selected_papers.liquid %}
  </div>
{% endif %}

<!-- Contact / Social -->
{% if page.social %}
  <div class="lab-section lab-section--alt">
    <h2 class="lab-section__heading">{{ t.home.contact_heading }}</h2>
    <div class="lab-contact">
      <div class="lab-contact__address">
        <h3 class="lab-contact__label"><i class="fas fa-map-marker-alt"></i> {{ t.home.address_label | default: "Address" }}</h3>
        <p>{{ t.home.address_line1 }}</p>
        <p>{{ t.home.address_line2 }}</p>
        <p>{{ t.home.address_line3 }}</p>
        <p>{{ t.home.address_line4 }}</p>
      </div>
      <div class="lab-contact__social">
        <h3 class="lab-contact__label"><i class="fas fa-link"></i> {{ t.home.social_label | default: "Connect" }}</h3>
        <div class="lab-contact__icons">
          {% if site.data.socials.email %}
            <a href="mailto:{{ site.data.socials.email }}" title="Email"><i class="fas fa-envelope"></i> <span>{{ site.data.socials.email }}</span></a>
          {% endif %}
          {% if site.data.socials.github %}
            <a href="https://github.com/{{ site.data.socials.github }}" target="_blank" rel="noopener noreferrer" title="GitHub"><i class="fab fa-github"></i> <span>{{ site.data.socials.github }}</span></a>
          {% endif %}
          {% if site.data.socials.scholar_userid %}
            <a href="https://scholar.google.com/citations?user={{ site.data.socials.scholar_userid }}" target="_blank" rel="noopener noreferrer" title="Google Scholar"><i class="ai ai-google-scholar"></i> <span>Google Scholar</span></a>
          {% endif %}
          {% if site.data.socials.researchgate %}
            <a href="https://www.researchgate.net/profile/{{ site.data.socials.researchgate }}" target="_blank" rel="noopener noreferrer" title="ResearchGate"><i class="ai ai-researchgate"></i> <span>ResearchGate</span></a>
          {% endif %}
          {% if site.data.socials.orcid %}
            <a href="https://orcid.org/{{ site.data.socials.orcid }}" target="_blank" rel="noopener noreferrer" title="ORCID"><i class="ai ai-orcid"></i> <span>ORCID</span></a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
{% endif %}
