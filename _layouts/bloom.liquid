<!DOCTYPE html>
<html lang="{{ page.lang | default: 'en' }}">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ page.title | default: site.title }}</title>
  <meta name="description" content="{{ page.description | default: site.description }}" />
  <!-- Tailwind CSS CDN for the legacy v2 surface -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'custom-orange': '#a72126',
            'custom-soft': '#f6f6f7',
          },
          fontWeight: {
            'extra-light': 200,
            light: 300,
          },
        },
      },
    }
  </script>
  <!-- Inter + Space Grotesk fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@700&display=swap" rel="stylesheet">
  <!-- Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/jpswalsh/academicons@1/css/academicons.min.css" />
  <!-- Legacy v2 overrides for Jekyll-generated components -->
  <link rel="stylesheet" href="{{ '/assets/css/bloom.css' | relative_url }}" />
  <style>
    :root { color-scheme: light !important; }
    body {
      font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      text-rendering: optimizeLegibility;
    }
    h1, h2, h3, h4, h5, h6, li, p { overflow-wrap: break-word; }
    a { text-decoration: underline; transition: color 0.25s; }
    a:hover { color: #a72126; }
    .bloom-nav a { text-decoration: none; }
    .bloom-logo-text { font-family: 'Space Grotesk', sans-serif; }
    .bloom-mobile-menu { display: none; }
    .bloom-mobile-menu.is-open { display: flex; }
  </style>
</head>
<body>
  {% assign lang = page.lang | default: 'en' %}
  {% assign t = site.data.i18n[lang] %}

  <div id="app" class="flex flex-col min-h-screen">

    <nav class="bloom-nav p-4">
      <div class="flex justify-between items-center w-full px-4 select-none">
        <a href="/v2/" class="flex items-center no-underline">
          <span class="bloom-logo-text text-lg font-bold text-custom-orange">
            Li Lab
          </span>
        </a>
        <button class="flex md:hidden text-gray-600" onclick="document.getElementById('bloom-menu').classList.toggle('is-open')">
          <i class="fas fa-bars h-6 w-6"></i>
        </button>
        <div id="bloom-menu" class="bloom-mobile-menu bg-custom-soft backdrop-blur-md md:backdrop-blur-none flex-col md:flex-row bg-opacity-75 md:bg-transparent md:flex md:items-center md:px-0 px-3 md:pb-0 pb-10 md:static absolute md:w-auto w-full md:h-auto h-full md:pt-0 pt-10 top-14 z-50 left-0">
          <a href="/v2/projects/" class="text-xl md:text-lg px-4 py-4 md:py-2 flex items-center justify-center md:flex-none md:items-stretch md:justify-start {% if page.url contains '/projects' %}text-custom-orange{% else %}text-gray-600{% endif %}">Research</a>
          <a href="/v2/publications/" class="text-xl md:text-lg px-4 py-4 md:py-2 flex items-center justify-center md:flex-none md:items-stretch md:justify-start {% if page.url contains '/publications' %}text-custom-orange{% else %}text-gray-600{% endif %}">Publications</a>
          <a href="/v2/clinical/" class="text-xl md:text-lg px-4 py-4 md:py-2 flex items-center justify-center md:flex-none md:items-stretch md:justify-start {% if page.url contains '/clinical' %}text-custom-orange{% else %}text-gray-600{% endif %}">Clinical</a>
          <a href="/v2/team/" class="text-xl md:text-lg px-4 py-4 md:py-2 flex items-center justify-center md:flex-none md:items-stretch md:justify-start {% if page.url contains '/team' %}text-custom-orange{% else %}text-gray-600{% endif %}">Team</a>
          <a href="/v2/news/" class="text-xl md:text-lg px-4 py-4 md:py-2 flex items-center justify-center md:flex-none md:items-stretch md:justify-start {% if page.url contains '/news' %}text-custom-orange{% else %}text-gray-600{% endif %}">News</a>
          <a href="/v2/careers/" class="text-xl md:text-lg px-4 py-4 md:py-2 flex items-center justify-center md:flex-none md:items-stretch md:justify-start {% if page.url contains '/careers' %}text-custom-orange{% else %}text-gray-600{% endif %}">Careers</a>
        </div>
      </div>
    </nav>

    <main class="flex-1 max-w-3xl mx-auto px-4 sm:px-6 lg:max-w-5xl xl:px-0 w-full">
      {{ content }}
    </main>

    <footer class="w-full p-4 bg-white text-center text-gray-400 text-sm">
      <p>&copy; {{ 'now' | date: "%Y" }} {{ site.title }}</p>
      <p class="text-xs mt-1">
        <a href="/v1/" class="text-gray-400 hover:text-custom-orange">Switch to Version A</a> · <a href="/versions/" class="text-gray-400 hover:text-custom-orange">View versions</a>
      </p>
    </footer>
  </div>
</body>
</html>
