<!DOCTYPE html>
<html lang="{{ page.lang | default: 'en' }}">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ page.title | default: site.title }}</title>
  <meta name="description" content="{{ page.description | default: site.description }}" />
  <link rel="stylesheet" href="{{ '/assets/css/bloom.css' | relative_url }}" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/jpswalsh/academicons@1/css/academicons.min.css" />
</head>
<body>
  {% assign lang = page.lang | default: 'en' %}
  {% assign t = site.data.i18n[lang] %}

  <div class="bloom-app">
    <!-- Navigation -->
    <nav class="bloom-nav" id="bloom-nav">
      <div class="bloom-nav__inner">
        <a class="bloom-nav__logo" href="/v2/">
          <span class="bloom-nav__logo-text">
            {% if lang == 'zh' %}衰老生物学实验室{% else %}Aging Biology Lab{% endif %}
          </span>
        </a>
        <button class="bloom-nav__toggle" aria-label="Toggle menu" onclick="this.closest('.bloom-nav').classList.toggle('is-open')">
          <i class="fas fa-bars"></i>
        </button>
        <div class="bloom-nav__links">
          <a href="/v2/projects/" {% if page.url contains '/projects' %}class="active"{% endif %}>Research</a>
          <a href="/v2/publications/" {% if page.url contains '/publications' %}class="active"{% endif %}>Publications</a>
          <a href="/v2/clinical/" {% if page.url contains '/clinical' %}class="active"{% endif %}>Clinical</a>
          <a href="/v2/people/" {% if page.url contains '/people' %}class="active"{% endif %}>People</a>
          <a href="/v2/news/" {% if page.url contains '/news' %}class="active"{% endif %}>News</a>
          <a href="/v2/careers/" {% if page.url contains '/careers' %}class="active"{% endif %}>Careers</a>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="bloom-main">
      {{ content }}
    </main>

    <!-- Footer -->
    <footer class="bloom-footer">
      <p>&copy; {{ 'now' | date: "%Y" }} {{ site.title }}</p>
      <p class="bloom-footer__switch">
        <a href="/v1/">Switch to Version A</a> · <a href="/">Back to chooser</a>
      </p>
    </footer>
  </div>
</body>
</html>
