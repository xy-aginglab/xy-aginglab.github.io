---
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ page.entry.title }} — Aging Biology Lab</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'custom-orange': '#a72126',
            'custom-soft': '#f6f6f7',
          },
        },
      },
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
  <style>
    body {
      font-family: 'Inter', ui-sans-serif, system-ui, sans-serif;
      -webkit-font-smoothing: antialiased;
    }
    a { text-decoration: underline; transition: color 0.25s; }
    a:hover { color: #a72126; }
    .bloom-nav a { text-decoration: none; }
    .bloom-logo-text { font-family: 'Space Grotesk', sans-serif; }
  </style>
</head>
<body>
  <div class="flex flex-col min-h-screen">
    <!-- Nav -->
    <nav class="bloom-nav p-4">
      <div class="flex justify-between items-center w-full px-4 select-none">
        <a href="/v2/" class="flex items-center no-underline">
          <span class="bloom-logo-text text-lg font-bold text-custom-orange">Aging Biology Lab</span>
        </a>
        <div class="hidden md:flex md:items-center">
          <a href="/v2/projects/" class="text-lg px-4 py-2 text-gray-600">Research</a>
          <a href="/v2/publications/" class="text-lg px-4 py-2 text-custom-orange">Publications</a>
          <a href="/v2/clinical/" class="text-lg px-4 py-2 text-gray-600">Clinical</a>
          <a href="/v2/team/" class="text-lg px-4 py-2 text-gray-600">Team</a>
          <a href="/v2/news/" class="text-lg px-4 py-2 text-gray-600">News</a>
          <a href="/v2/careers/" class="text-lg px-4 py-2 text-gray-600">Careers</a>
        </div>
      </div>
    </nav>

    <!-- Paper detail -->
    <main class="flex-1 max-w-3xl mx-auto px-4 sm:px-6 lg:max-w-5xl xl:px-0 w-full">
      <div class="mx-auto max-w-4xl">
        <!-- DEBUG -->
        <pre>
        page.title = [{{ page.title }}]
        page.entry = [{{ page.entry }}]
        page.entry.title = [{{ page.entry.title }}]
        page.entry.author = [{{ page.entry.author }}]
        page.key = [{{ page.key }}]
        page.bibtex = [{{ page.bibtex }}]
        content = [{{ content }}]
        </pre>
        <!-- END DEBUG -->
        <!-- Journal + Year -->
        <div class="flex items-center divide-x divide-gray-300 text-gray-500 mb-3">
          {% if page.entry.journal %}
            <span class="pr-3 italic text-lg">{{ page.entry.journal }}</span>
          {% elsif page.entry.booktitle %}
            <span class="pr-3 italic text-lg">{{ page.entry.booktitle }}</span>
          {% endif %}
          {% if page.entry.year %}
            <span class="pl-3 text-lg">{{ page.entry.year }}</span>
          {% endif %}
        </div>

        <!-- Title -->
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-800 tracking-tight my-3">
          {{ page.title }}
        </h1>

        <!-- Authors -->
        {% if page.entry.author %}
          <p class="text-gray-500 font-medium text-lg my-3">
            {{ page.entry.author }}
          </p>
        {% endif %}

        <!-- DOI -->
        {% if page.entry.doi %}
          <p class="text-gray-500 my-3">
            <a href="https://doi.org/{{ page.entry.doi }}">doi:{{ page.entry.doi }}</a>
          </p>
        {% endif %}

        <!-- Abstract -->
        {% if page.entry.abstract %}
          <div class="mt-6 pt-6 border-t border-gray-200">
            <h2 class="text-xl font-semibold text-gray-800 mb-3">Abstract</h2>
            <p class="text-gray-700 leading-7">{{ page.entry.abstract }}</p>
          </div>
        {% endif %}

        <!-- Back link -->
        <div class="mt-8 mb-12">
          <a href="/v2/publications/" class="text-custom-orange no-underline font-medium">← Back to all papers</a>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer class="w-full p-4 bg-white text-center text-gray-400 text-sm">
      <p>&copy; {{ 'now' | date: "%Y" }} Hunan Key Laboratory of Aging Biology</p>
    </footer>
  </div>
</body>
</html>
