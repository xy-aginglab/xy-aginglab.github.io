---
layout: bloom
---
<!-- Paper.vue detail page — matches Bloom Lab Paper component -->
<div class="mx-auto max-w-4xl prose">
  <!-- Journal + Year -->
  <div class="flex items-center divide-x divide-gray-300 text-gray-500 mb-3">
    {% if page.journal %}
      <span class="pr-3 italic text-lg">{{ page.journal }}</span>
    {% endif %}
    {% if page.year %}
      <span class="pl-3 text-lg">{{ page.year }}</span>
    {% endif %}
  </div>

  <!-- Title -->
  <h1 class="text-3xl sm:text-4xl font-bold text-gray-800 tracking-tight my-3">
    {{ page.title }}
  </h1>

  <!-- Authors -->
  {% if page.authors %}
    <p class="text-gray-500 font-medium text-lg my-3">
      {{ page.authors }}
    </p>
  {% endif %}

  <!-- DOI -->
  {% if page.doi %}
    <p class="text-gray-500 my-3">
      <a href="https://doi.org/{{ page.doi }}">doi:{{ page.doi }}</a>
    </p>
  {% endif %}

  <!-- Abstract / Content -->
  <div class="text-gray-700 leading-7 mt-6">
    {{ content }}
  </div>
</div>
