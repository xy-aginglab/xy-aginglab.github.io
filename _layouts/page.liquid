---
layout: default
---
{% assign lang = page.lang | default: 'en' %}
{% assign t = site.data.i18n[lang] %}

{% if page._styles %}
  <!-- Page/Post style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

<!-- Page Header -->
<div class="lab-section lab-page-header">
  <h2 class="lab-section__heading">{{ page.title }}</h2>
  {% if page.description %}
    <p class="lab-page-header__desc">{{ page.description }}</p>
  {% endif %}
</div>

<!-- Page Content -->
<div class="lab-section">
  <div class="lab-page-content">
    <article>
      {{ content }}
    </article>

    {% if page.related_publications %}
      <h2>References</h2>
      <div class="publications">
        {% bibliography --cited_in_order %}
      </div>
    {% endif %}

    {% if site.giscus and page.giscus_comments %}
      {% include giscus.liquid %}
    {% endif %}
  </div>
</div>
