{% assign lang = page.lang | default: 'en' %}
{% assign t = site.data.i18n[lang] %}
<!doctype html>
<html lang="{{ lang }}">
  <head>
    {% if page.redirect %}
      {% if page.redirect == true %}
        {% assign redirect = site.baseurl | append: '/' %}
      {% elsif page.redirect contains '://' %}
        {% assign redirect = page.redirect %}
      {% else %}
        {% assign redirect = page.redirect | relative_url %}
      {% endif %}
      <meta http-equiv="refresh" content="3; url={{ redirect }}">
    {% endif %}
    {% include head.liquid %}
  </head>

  <body>
    <!-- Lab Navigation -->
    <nav class="lab-nav{% if page.layout == 'about' %} lab-nav--at-top{% endif %}">
      <div class="lab-nav__inner">
        {% if lang == 'zh' %}
          <a class="lab-nav__brand" href="{{ '/v1/zh/' | relative_url }}">Li Lab</a>
        {% else %}
          <a class="lab-nav__brand" href="{{ '/v1/' | relative_url }}">{{ site.title }}</a>
        {% endif %}
        <button class="lab-nav__toggle" aria-label="Toggle navigation" onclick="this.closest('.lab-nav').classList.toggle('is-open')">
          <span></span><span></span><span></span>
        </button>
        <ul class="lab-nav__links">
          {% if lang == 'zh' %}
            <li
              {% if page.url == '/v1/zh/' %}
                class="active"
              {% endif %}
            >
              <a href="{{ '/v1/zh/' | relative_url }}">{{ t.nav.home }}</a>
            </li>
            <li
              {% if page.url contains '/v1/zh/projects' %}
                class="active"
              {% endif %}
            >
              <a href="{{ '/v1/zh/projects/' | relative_url }}">{{ t.nav.projects }}</a>
            </li>
            <li
              {% if page.url contains '/v1/zh/publications' %}
                class="active"
              {% endif %}
            >
              <a href="{{ '/v1/zh/publications/' | relative_url }}">{{ t.nav.publications }}</a>
            </li>
            <li
              {% if page.url contains '/v1/zh/clinical' %}
                class="active"
              {% endif %}
            >
              <a href="{{ '/v1/zh/clinical/' | relative_url }}">{{ t.nav.clinical }}</a>
            </li>
            <li
              {% if page.url contains '/v1/zh/people' %}
                class="active"
              {% endif %}
            >
              <a href="{{ '/v1/zh/people/' | relative_url }}">{{ t.nav.people }}</a>
            </li>
            <li
              {% if page.url contains '/v1/zh/careers' %}
                class="active"
              {% endif %}
            >
              <a href="{{ '/v1/zh/careers/' | relative_url }}">{{ t.nav.careers }}</a>
            </li>
          {% else %}
            {% assign sorted_pages = site.pages | sort: 'nav_order' %}
            {% for p in sorted_pages %}
              {% if p.nav and p.autogen == null and p.dropdown == null and p.lang == null %}
                {% assign parent_link = p.permalink | remove: 'index.html' %}
                <li
                  {% if page.url contains parent_link %}
                    class="active"
                  {% endif %}
                >
                  <a href="{{ p.url | relative_url }}">{{ p.title }}</a>
                </li>
              {% endif %}
            {% endfor %}
          {% endif %}

          <!-- Language Switcher -->
          {% assign switch_url = nil %}
          {% if lang == 'zh' %}
            {% case page.url %}
              {% when '/v1/zh/' %}
                {% assign switch_url = '/v1/' %}
              {% when '/v1/zh/projects/' %}
                {% assign switch_url = '/v1/projects/' %}
              {% when '/v1/zh/publications/' %}
                {% assign switch_url = '/v1/publications/' %}
              {% when '/v1/zh/clinical/' %}
                {% assign switch_url = '/v1/clinical/' %}
              {% when '/v1/zh/people/' %}
                {% assign switch_url = '/v1/people/' %}
              {% when '/v1/zh/careers/' %}
                {% assign switch_url = '/v1/careers/' %}
            {% endcase %}
          {% else %}
            {% case page.url %}
              {% when '/v1/' %}
                {% assign switch_url = '/v1/zh/' %}
              {% when '/v1/projects/' %}
                {% assign switch_url = '/v1/zh/projects/' %}
              {% when '/v1/publications/' %}
                {% assign switch_url = '/v1/zh/publications/' %}
              {% when '/v1/clinical/' %}
                {% assign switch_url = '/v1/zh/clinical/' %}
              {% when '/v1/people/' %}
                {% assign switch_url = '/v1/zh/people/' %}
              {% when '/v1/careers/' %}
                {% assign switch_url = '/v1/zh/careers/' %}
            {% endcase %}
          {% endif %}
          {% if switch_url %}
            <li class="lab-nav__lang-switch">
              {% if lang == 'zh' %}
                <a href="{{ switch_url | relative_url }}" title="Switch to English">EN</a>
              {% else %}
                <a href="{{ switch_url | relative_url }}" title="切换到中文">中文</a>
              {% endif %}
            </li>
          {% endif %}

          {% if site.enable_darkmode %}
            <li class="lab-nav__theme-toggle">
              <button id="light-toggle" title="Change theme">
                <i class="fa-half-sun-moon" id="light-toggle-system"></i>
                <i class="fa-solid fa-moon" id="light-toggle-dark"></i>
                <i class="fa-solid fa-sun" id="light-toggle-light"></i>
              </button>
            </li>
          {% endif %}
        </ul>
      </div>
    </nav>

    <!-- Content -->
    <main class="lab-main">
      {{ content }}
    </main>

    <!-- Affiliations Logo Bar -->
    <div class="lab-logos">
      <div class="lab-logos__inner">
        <img src="{{ '/assets/img/logos/csu.png' | relative_url }}" alt="Central South University">
        <img src="{{ '/assets/img/logos/xiangya.png' | relative_url }}" alt="Xiangya Hospital">
        <img src="{{ '/assets/img/logos/aging_lab.png' | relative_url }}" alt="Li Lab">
        <img src="{{ '/assets/img/logos/research_center.png' | relative_url }}" alt="Skin Aging and Hair Regeneration Research Center">
      </div>
    </div>

    <!-- Footer -->
    <footer class="lab-footer">
      <div class="lab-footer__inner">
        <p>
          &copy; {{ site.time | date: '%Y' }}
          {% if lang == 'zh' %}Li Lab{% else %}{{ site.title }}{% endif %}. {{ t.footer.powered_by }}
          <a href="https://jekyllrb.com/" target="_blank" rel="noopener noreferrer">Jekyll</a>.
          {{ t.footer.hosted_by }}
          <a href="https://pages.github.com/" target="_blank" rel="noopener noreferrer">GitHub Pages</a>.
        </p>
        <p style="margin-top:0.4rem;font-size:0.8rem;opacity:0.7">
          <a href="/v2/" style="color:inherit">Version B</a> · <a href="/v3/" style="color:inherit">Version C</a> · <a href="/versions/" style="color:inherit">View versions</a>
        </p>
      </div>
    </footer>

    {% include scripts.liquid %}
    <script src="{{ '/assets/js/bib-toggle.js' | relative_url }}"></script>

    <!-- Nav scroll effect: transparent at top, themed on scroll (homepage only) -->
    {% if page.layout == 'about' %}
      <script>
        (function () {
          var nav = document.querySelector('.lab-nav');
          if (!nav) return;
          var threshold = 80;
          function onScroll() {
            if (window.scrollY > threshold) {
              nav.classList.remove('lab-nav--at-top');
            } else {
              nav.classList.add('lab-nav--at-top');
            }
          }
          window.addEventListener('scroll', onScroll, { passive: true });
          onScroll();
        })();
      </script>
    {% endif %}
  </body>
</html>
