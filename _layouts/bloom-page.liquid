---
layout: bloom
---
{%- comment -%}
  Matches Bloom Lab page pattern:
  pt-6 pb-8 space-y-2 md:space-y-5 header → divide-y → content
{%- endcomment -%}
<div class="bloom-page-header">
  <h1>{{ page.title }}</h1>
  {% if page.description %}
    <p>{{ page.description }}</p>
  {% endif %}
</div>
<hr class="bloom-page-divider">
<div class="bloom-prose">
  {{ content }}
</div>
