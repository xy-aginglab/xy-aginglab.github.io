---
layout: v3
---
{% assign lang = page.lang | default: 'en' %}
{% assign t = site.data.i18n[lang] %}
{% assign pi = site.data.members | where: 'role', 'pi' %}
{% assign basic = site.data.members | where: 'role', 'basic_researcher' %}
{% assign clinical = site.data.members | where: 'role', 'clinical_researcher' %}
{% assign techs = site.data.members | where: 'role', 'technician' %}
{% assign has_page_links = false %}
{% if page.page_links and page.page_links.size > 0 %}
  {% assign has_page_links = true %}
{% endif %}
{% assign show_page_eyebrow = true %}
{% if page.show_eyebrow == false %}
  {% assign show_page_eyebrow = false %}
{% endif %}
{% assign show_page_lead = true %}
{% if page.show_lead == false %}
  {% assign show_page_lead = false %}
{% endif %}
{% assign page_shift_class = '' %}
{% if page.content_offset_right %}
  {% assign page_shift_class = ' v3-page--offset' %}
{% endif %}

<section class="v3-page v3-team-page{{ page_shift_class }}">
  <div class="v3-page__masthead">
    <header class="v3-page__header">
      {% if show_page_eyebrow and page.eyebrow %}
        <p class="v3-page__eyebrow">{{ page.eyebrow }}</p>
      {% endif %}
      <h1>{{ page.title }}</h1>
      {% if show_page_lead and page.lead %}
        <p class="v3-page__lead">{{ page.lead }}</p>
      {% elsif show_page_lead and page.description %}
        <p class="v3-page__lead">{{ page.description }}</p>
      {% endif %}
      {% if has_page_links %}
        <nav class="v3-page__links" aria-label="{{ page.page_links_title | default: 'Related links' }}">
          {% for link in page.page_links %}
            {% assign link_href = link.href %}
            {% assign link_external = false %}
            {% if link_href == 'email' %}
              {% assign link_href = 'mailto:' | append: site.data.socials.email %}
            {% elsif link_href contains '://' or link_href contains 'mailto:' %}
              {% assign link_external = true %}
            {% else %}
              {% assign link_href = link_href | relative_url %}
            {% endif %}
            <a href="{{ link_href }}"{% if link_external and link_href contains '://' %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ link.label }}</a>
          {% endfor %}
        </nav>
      {% endif %}
    </header>
  </div>

  <div class="v3-people">
    {% if pi.size > 0 %}
      {% for member in pi %}
        {% if lang == 'zh' %}
          {% assign pi_bio_blocks = member.bio_zh | default: member.bio | split: '<br><br>' %}
        {% else %}
          {% assign pi_bio_blocks = member.bio | split: '<br><br>' %}
        {% endif %}
        {% assign has_pi_links = false %}
        {% if member.email or member.scholar or member.orcid or member.researchgate %}
          {% assign has_pi_links = true %}
        {% endif %}
        <section class="v3-person-group">
          <h2 class="v3-group__title">{{ t.people.pi }}</h2>
          <article class="v3-pi-card">
            <img src="{{ member.photo | relative_url }}" alt="{% if lang == 'zh' %}{{ member.name }}{% else %}{{ member.name_en | default: member.name }}{% endif %}" loading="lazy">
            <div class="v3-pi-card__content">
              <h3 class="v3-pi-card__name">{% if lang == 'zh' %}{{ member.name }}{% else %}{{ member.name_en | default: member.name }}{% endif %}</h3>
              <p class="v3-pi-card__meta">{% if lang == 'zh' %}{{ member.title }}{% else %}{{ member.title_en | default: member.title }}{% endif %}</p>
              {% if member.bio %}
                <div class="v3-pi-card__bio">
                  {% for bio_block in pi_bio_blocks limit: 1 %}
                    {% assign bio_copy = bio_block | strip %}
                    {% if bio_copy != '' %}
                      <p>{{ bio_copy }}</p>
                    {% endif %}
                  {% endfor %}
                </div>
              {% endif %}
              {% if has_pi_links %}
                <div class="v3-pi-card__links">
                  {% if member.email %}<a href="mailto:{{ member.email }}" title="Email"><i class="fas fa-envelope"></i></a>{% endif %}
                  {% if member.scholar %}<a href="https://scholar.google.com/citations?user={{ member.scholar }}" target="_blank" rel="noopener noreferrer" title="Google Scholar"><i class="ai ai-google-scholar"></i></a>{% endif %}
                  {% if member.orcid and member.orcid != '0000-0002-0000-0000' %}<a href="https://orcid.org/{{ member.orcid }}" target="_blank" rel="noopener noreferrer" title="ORCID"><i class="ai ai-orcid"></i></a>{% endif %}
                  {% if member.researchgate %}<a href="https://www.researchgate.net/profile/{{ member.researchgate }}" target="_blank" rel="noopener noreferrer" title="ResearchGate"><i class="ai ai-researchgate"></i></a>{% endif %}
                </div>
              {% endif %}
            </div>
          </article>
        </section>
      {% endfor %}
    {% endif %}

    {% if basic.size > 0 %}
      <section class="v3-person-group">
        <h2 class="v3-group__title">{{ t.people.basic_researchers }}</h2>
        <div class="v3-person-grid">
          {% for member in basic %}
            {% assign has_member_links = false %}
            {% assign show_photo = true %}
            {% if member.email or member.scholar or member.orcid %}
              {% assign has_member_links = true %}
            {% endif %}
            {% if member.photo == nil or member.photo contains 'placeholder.png' %}
              {% assign show_photo = false %}
            {% endif %}
            {% if show_photo %}
              <article class="v3-person-card">
                <img src="{{ member.photo | relative_url }}" alt="{% if lang == 'zh' %}{{ member.name }}{% else %}{{ member.name_en | default: member.name }}{% endif %}" loading="lazy">
                <div class="v3-person-card__body">
                  <h3 class="v3-person-card__name">{% if lang == 'zh' %}{{ member.name }}{% else %}{{ member.name_en | default: member.name }}{% endif %}</h3>
                  <p class="v3-person-card__meta">{% if lang == 'zh' %}{{ member.title }}{% else %}{{ member.title_en | default: member.title }}{% endif %}</p>
                  {% if has_member_links %}
                    <div class="v3-person-links">
                      {% if member.email %}<a href="mailto:{{ member.email }}" title="Email"><i class="fas fa-envelope"></i></a>{% endif %}
                      {% if member.scholar %}<a href="https://scholar.google.com/citations?user={{ member.scholar }}" target="_blank" rel="noopener noreferrer" title="Google Scholar"><i class="ai ai-google-scholar"></i></a>{% endif %}
                      {% if member.orcid and member.orcid != '0000-0002-0000-0000' %}<a href="https://orcid.org/{{ member.orcid }}" target="_blank" rel="noopener noreferrer" title="ORCID"><i class="ai ai-orcid"></i></a>{% endif %}
                    </div>
                  {% endif %}
                </div>
              </article>
            {% endif %}
          {% endfor %}
        </div>
        <div class="v3-person-roster">
          {% for member in basic %}
            {% assign has_member_links = false %}
            {% assign show_photo = true %}
            {% if member.email or member.scholar or member.orcid %}
              {% assign has_member_links = true %}
            {% endif %}
            {% if member.photo == nil or member.photo contains 'placeholder.png' %}
              {% assign show_photo = false %}
            {% endif %}
            {% unless show_photo %}
              <article class="v3-person-row">
                <div>
                  <h3 class="v3-person-card__name">{% if lang == 'zh' %}{{ member.name }}{% else %}{{ member.name_en | default: member.name }}{% endif %}</h3>
                  <p class="v3-person-card__meta">{% if lang == 'zh' %}{{ member.title }}{% else %}{{ member.title_en | default: member.title }}{% endif %}</p>
                </div>
                {% if has_member_links %}
                  <div class="v3-person-links">
                    {% if member.email %}<a href="mailto:{{ member.email }}" title="Email"><i class="fas fa-envelope"></i></a>{% endif %}
                    {% if member.scholar %}<a href="https://scholar.google.com/citations?user={{ member.scholar }}" target="_blank" rel="noopener noreferrer" title="Google Scholar"><i class="ai ai-google-scholar"></i></a>{% endif %}
                    {% if member.orcid and member.orcid != '0000-0002-0000-0000' %}<a href="https://orcid.org/{{ member.orcid }}" target="_blank" rel="noopener noreferrer" title="ORCID"><i class="ai ai-orcid"></i></a>{% endif %}
                  </div>
                {% endif %}
              </article>
            {% endunless %}
          {% endfor %}
        </div>
      </section>
    {% endif %}

