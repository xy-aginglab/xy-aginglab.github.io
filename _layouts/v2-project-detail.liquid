---
layout: v2
---
{% assign lang = page.lang | default: 'en' %}
<div class="v2-page">
  <header class="v2-page__header">
    <h1 class="v2-page__title">{{ page.title }}</h1>
  </header>
  <article class="v2-page__content v3-rich">
    {% if page.img %}
      <img src="{{ page.img | replace: '.svg', '.png' | prepend: '/assets/img/' | relative_url }}" alt="{{ page.title }}" style="width:min(100%,32rem);border-radius:16px;margin-bottom:1.5rem;">
    {% endif %}

    {% if page.research_direction %}
      {% for dir in site.data.research_directions %}
        {% if dir.id == page.research_direction %}
          {% if lang == 'zh' %}{{ dir.narrative_zh }}{% else %}{{ dir.narrative }}{% endif %}
        {% endif %}
      {% endfor %}
    {% endif %}

    {{ content }}

    <p style="margin-top:2.5rem;">
      {% if lang == 'zh' %}
        <a href="{{ '/zh/projects/' | relative_url }}">&larr; 返回科研方向</a>
      {% else %}
        <a href="{{ '/projects/' | relative_url }}">&larr; Back to research</a>
      {% endif %}
    </p>
  </article>
</div>
