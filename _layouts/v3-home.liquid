<!DOCTYPE html>
<html lang="{{ page.lang | default: 'en' }}">
<head>
  {% assign asset_version = site.time | date: '%s' %}
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{% if page.title %}{{ page.title }} | {% endif %}{{ site.title }}</title>
  <meta name="description" content="{{ page.description | default: site.description | strip_html | truncatewords: 50 }}" />
  <link rel="canonical" href="{{ page.url | replace:'index.html','' | absolute_url }}">
  <meta property="og:title" content="{{ page.title | default: site.title }}">
  <meta property="og:description" content="{{ page.description | default: site.description | strip_html | truncatewords: 50 }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ page.url | absolute_url }}">
  {% if site.icon %}
    {% assign icon_value = site.icon | strip %}
    {% if icon_value contains '://' %}
      {% assign favicon_href = icon_value %}
    {% elsif icon_value contains '/' or icon_value contains '.' %}
      {% assign favicon_href = icon_value | relative_url %}
    {% else %}
      {% capture emoji_svg %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><text y=".9em" font-size="90">{{ icon_value }}</text></svg>{% endcapture %}
      {% assign emoji_svg_escaped = emoji_svg | uri_escape %}
      {% assign favicon_href = 'data:image/svg+xml,' | append: emoji_svg_escaped %}
    {% endif %}
    <link rel="icon" href="{{ favicon_href }}">
  {% endif %}
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            "custom-orange": "#a24f39",
            "custom-soft": "#f5efe7"
          }
        }
      }
    };
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lora:ital,wght@0,500;0,700;1,500&family=Manrope:wght@400;500;600;700;800&family=Newsreader:opsz,wght@6..72,500;6..72,700&family=Fira+Code:wght@400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
  <link rel="stylesheet" href="{{ '/assets/css/academicons.min.css' | relative_url }}" />
  <link rel="stylesheet" href="{{ '/assets/css/v3.css?v=' | append: asset_version | relative_url }}" />
  <link rel="stylesheet" href="{{ '/assets/css/v3-home.css?v=' | append: asset_version | relative_url }}" />
  <script>
    (function(){
      var s = localStorage.getItem('v3-theme');
      if (s !== 'dark' && s !== 'light') s = 'system';
      var t = s;
      if (s === 'system') {
        t = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }
      if (t === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
    })();
  </script>
</head>
<body>
  {% assign current_url = page.url | default: '' %}
  {% assign lang = page.lang | default: 'en' %}
  <div class="v3-shell">
    <nav class="v3-nav" data-v3-nav>
      <div class="v3-nav__inner v3-nav__inner--home">
        {% if lang == 'zh' %}
        <a class="v3-brand" href="{{ '/v3/zh/' | relative_url }}" aria-label="Li Lab">
          <span class="v3-brand__title">Li Lab</span>
        </a>
        {% else %}
        <a class="v3-brand" href="{{ '/v3/' | relative_url }}" aria-label="Li Lab">
          <span class="v3-brand__title">Li Lab</span>
        </a>
        {% endif %}
        <button class="v3-nav__toggle" type="button" aria-controls="v3-primary-nav" aria-expanded="false" aria-label="Toggle site navigation" data-v3-nav-toggle>
          <span></span><span></span><span></span>
        </button>
        <div class="v3-nav__menu" id="v3-primary-nav" data-v3-nav-menu>
          {% if lang == 'zh' %}
          <div class="v3-nav__menu-main">
            <a href="{{ '/v3/zh/projects/' | relative_url }}"{% if current_url contains '/v3/zh/projects' %} class="is-active"{% endif %}>科研方向</a>
            <a href="{{ '/v3/zh/publications/' | relative_url }}"{% if current_url contains '/v3/zh/publications' %} class="is-active"{% endif %}>论文发表</a>
            <a href="{{ '/v3/zh/team/' | relative_url }}"{% if current_url contains '/v3/zh/team' %} class="is-active"{% endif %}>团队成员</a>
          </div>
          <div class="v3-nav__utility" aria-label="Additional pages">
            <a href="{{ '/v3/zh/clinical/' | relative_url }}"{% if current_url contains '/v3/zh/clinical' %} class="is-active"{% endif %}>临床研究</a>
            <a href="{{ '/v3/zh/contact/' | relative_url }}"{% if current_url contains '/v3/zh/contact' %} class="is-active"{% endif %}>联系我们</a>
            <a href="{{ '/v3/' | relative_url }}">EN</a>
            <button type="button" class="v3-theme-toggle" data-v3-theme-toggle aria-label="Toggle dark mode"><i class="fas fa-circle-half-stroke"></i></button>
          </div>
          {% else %}
          <div class="v3-nav__menu-main">
            <a href="{{ '/v3/projects/' | relative_url }}"{% if current_url contains '/v3/projects' %} class="is-active"{% endif %}>Research</a>
            <a href="{{ '/v3/publications/' | relative_url }}"{% if current_url contains '/v3/publications' or current_url contains '/bibliography/' %} class="is-active"{% endif %}>Publications</a>
            <a href="{{ '/v3/team/' | relative_url }}"{% if current_url contains '/v3/team' %} class="is-active"{% endif %}>Team</a>
          </div>
          <div class="v3-nav__utility" aria-label="Additional pages">
            <a href="{{ '/v3/clinical/' | relative_url }}"{% if current_url contains '/v3/clinical' %} class="is-active"{% endif %}>Clinical</a>
            <a href="{{ '/v3/contact/' | relative_url }}"{% if current_url contains '/v3/contact' %} class="is-active"{% endif %}>Contact</a>
            <a href="{{ '/v3/zh/' | relative_url }}">中文</a>
            <button type="button" class="v3-theme-toggle" data-v3-theme-toggle aria-label="Toggle dark mode"><i class="fas fa-circle-half-stroke"></i></button>
          </div>
          {% endif %}
        </div>
      </div>
    </nav>

    <main class="v3-main">
      {{ content }}
    </main>

    <footer class="v3-logos">
      <div class="v3-logos__inner">
        <img src="{{ '/assets/img/logos/csu.png' | relative_url }}" alt="Central South University" loading="lazy">
        <img src="{{ '/assets/img/logos/xiangya.png' | relative_url }}" alt="Xiangya Hospital" loading="lazy">
        <img src="{{ '/assets/img/logos/aging_lab.png' | relative_url }}" alt="Li Lab" loading="lazy">
        <img src="{{ '/assets/img/logos/research_center.png' | relative_url }}" alt="Skin Aging and Hair Regeneration Research Center" loading="lazy">
      </div>
      <p class="v3-logos__copy">&copy; {{ 'now' | date: '%Y' }} {{ site.title }}.</p>
    </footer>
  </div>

  <script src="{{ '/assets/js/v3.js?v=' | append: asset_version | relative_url }}"></script>
</body>
</html>
