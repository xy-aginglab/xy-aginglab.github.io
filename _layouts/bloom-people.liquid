---
layout: bloom
---
{% assign lang = page.lang | default: 'en' %}
{% assign t = site.data.i18n[lang] %}

<div class="pt-6 pb-8 space-y-2 md:space-y-5">
  <h1 class="text-3xl leading-9 font-bold text-gray-800 tracking-tight sm:text-4xl sm:leading-10 md:text-6xl md:leading-14">
    {{ t.people.page_title }}
  </h1>
</div>
<div class="w-full border-t border-gray-200"></div>

<!-- PI Section -->
{% assign pi = site.data.members | where: 'role', 'pi' %}
{% if pi.size > 0 %}
  <div class="category-section my-6">
    <div class="pt-6 pb-8 space-y-2 md:space-y-5">
      <h1 class="text-xl leading-9 font-bold text-gray-800 tracking-tight text-center md:text-left sm:text-2xl sm:leading-10 md:text-4xl md:leading-14">
        {{ t.people.pi }}
      </h1>
    </div>
    {% for member in pi %}
      <div class="flex flex-col sm:flex-row gap-8 items-start">
        <div class="flex-shrink-0 w-44">
          <img src="{{ member.photo | relative_url }}" alt="{{ member.name }}" class="w-full rounded-lg" loading="lazy">
        </div>
        <div>
          <h3 class="text-xl font-bold text-gray-800 mb-1">
            {% if lang == 'zh' %}{{ member.name }}{% else %}{{ member.name_en }}{% endif %}
          </h3>
          <p class="text-sm text-gray-600 mb-3">
            {% if lang == 'zh' %}{{ member.title }}{% else %}{{ member.title_en }}{% endif %}
          </p>
          <p class="text-sm text-gray-500 leading-7">
            {% if lang == 'zh' %}{{ member.bio_zh | default: member.bio }}{% else %}{{ member.bio }}{% endif %}
          </p>
          <div class="flex gap-3 mt-3">
            {% if member.email %}<a href="mailto:{{ member.email }}" class="text-gray-500 hover:text-custom-orange no-underline text-lg"><i class="fas fa-envelope"></i></a>{% endif %}
            {% if member.scholar %}<a href="https://scholar.google.com/citations?user={{ member.scholar }}" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-custom-orange no-underline text-lg"><i class="ai ai-google-scholar"></i></a>{% endif %}
            {% if member.orcid and member.orcid != '0000-0002-0000-0000' %}<a href="https://orcid.org/{{ member.orcid }}" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-custom-orange no-underline text-lg"><i class="ai ai-orcid"></i></a>{% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
{% endif %}

{% assign basic = site.data.members | where: 'role', 'basic_researcher' %}
{% if basic.size > 0 %}
  <div class="category-section my-6">
    <div class="pt-6 pb-8 space-y-2 md:space-y-5">
      <h1 class="text-xl leading-9 font-bold text-gray-800 tracking-tight text-center md:text-left sm:text-2xl sm:leading-10 md:text-4xl md:leading-14">
        {{ t.people.basic_researchers }}
      </h1>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {% for member in basic %}
        <article class="hover:shadow-lg hover:shadow-custom-orange flex flex-col gap-px rounded-lg w-full h-full overflow-hidden transition-shadow duration-300 ease-in-out">
          <div class="py-6 px-4 sm:py-8 sm:px-6 flex-grow bg-custom-soft cursor-pointer">
            <figure class="relative shrink-0 mx-auto w-36 h-36 rounded-full overflow-hidden shadow">
              <img class="absolute inset-0 w-full h-full object-cover" src="{{ member.photo | relative_url }}" alt="{{ member.name }}" loading="lazy">
            </figure>
            <div class="text-center pt-6">
              <h1 class="m-0 text-gray-800 font-semibold tracking-wide leading-7 text-lg ease-in-out">
                {% if lang == 'zh' %}{{ member.name }}{% else %}{{ member.name_en }}{% endif %}
              </h1>
              <p class="m-0 font-medium text-gray-600 pt-1 text-base">
                {% if lang == 'zh' %}{{ member.title }}{% else %}{{ member.title_en }}{% endif %}
              </p>
              <div class="flex justify-center h-14 pt-4 px-3">
                {% if member.email %}<a href="mailto:{{ member.email }}" class="flex justify-center items-center w-9 h-9 text-gray-500 hover:text-custom-orange no-underline"><i class="fas fa-envelope"></i></a>{% endif %}
                {% if member.scholar %}<a href="https://scholar.google.com/citations?user={{ member.scholar }}" target="_blank" rel="noopener noreferrer" class="flex justify-center items-center w-9 h-9 text-gray-500 hover:text-custom-orange no-underline"><i class="ai ai-google-scholar"></i></a>{% endif %}
                {% if member.orcid and member.orcid != '0000-0002-0000-0000' %}<a href="https://orcid.org/{{ member.orcid }}" target="_blank" rel="noopener noreferrer" class="flex justify-center items-center w-9 h-9 text-gray-500 hover:text-custom-orange no-underline"><i class="ai ai-orcid"></i></a>{% endif %}
              </div>
            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
{% endif %}

