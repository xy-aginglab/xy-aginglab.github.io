<!DOCTYPE html>
<html lang="{{ page.lang | default: 'en' }}">
<head>
  {% assign asset_version = site.time | date: '%s' %}
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{% if page.title %}{{ page.title }} | {% endif %}{{ site.title }}</title>
  <meta name="description" content="{{ page.description | default: site.description | strip_html | truncatewords: 50 }}" />
  <link rel="canonical" href="{{ page.url | replace:'index.html','' | absolute_url }}">
  <!-- Open Graph -->
  <meta property="og:title" content="{{ page.title | default: site.title }}">
  <meta property="og:description" content="{{ page.description | default: site.description | strip_html | truncatewords: 50 }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ page.url | absolute_url }}">
  <meta property="og:site_name" content="{{ site.title }}">
  <meta property="og:image" content="{{ '/assets/img/og-image.png' | absolute_url }}">
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:image" content="{{ '/assets/img/og-image.png' | absolute_url }}">
  <meta name="twitter:title" content="{{ page.title | default: site.title }}">
  <meta name="twitter:description" content="{{ page.description | default: site.description | strip_html | truncatewords: 50 }}">
  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ResearchOrganization",
    "name": "Li Lab",
    "alternateName": "Li Lab, Xiangya Hospital",
    "url": "{{ '/' | absolute_url }}",
    "logo": "{{ '/assets/img/logos/aging_lab.png' | absolute_url }}",
    "description": "{{ site.description | strip_html | strip_newlines }}",
    "parentOrganization": {
      "@type": "Hospital",
      "name": "Xiangya Hospital, Central South University",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "87 Xiangya Road, Kaifu District",
        "addressLocality": "Changsha",
        "addressRegion": "Hunan",
        "postalCode": "410008",
        "addressCountry": "CN"
      }
    },
    "department": {
      "@type": "Organization",
      "name": "Department of Dermatology"
    },
    "knowsAbout": ["skin aging", "pilosebaceous-related diseases", "rosacea", "hair disorders", "inflammatory skin diseases"]
  }
  </script>
  {% if site.icon %}
    {% assign icon_value = site.icon | strip %}
    {% if icon_value contains '://' %}{% assign favicon_href = icon_value %}
    {% elsif icon_value contains '/' or icon_value contains '.' %}{% assign favicon_href = icon_value | relative_url %}
    {% else %}{% capture emoji_svg %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><text y=".9em" font-size="90">{{ icon_value }}</text></svg>{% endcapture %}{% assign favicon_href = 'data:image/svg+xml,' | append: emoji_svg | uri_escape %}{% endif %}
    <link rel="icon" href="{{ favicon_href }}">
  {% endif %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700&family=Noto+Serif+SC:wght@500;700&family=Source+Sans+3:wght@400;600;700&family=Merriweather:wght@400;700;900&family=Libre+Baskerville:wght@400;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
  <link rel="stylesheet" href="{{ '/assets/css/v2-home.css?v=' | append: asset_version | relative_url }}" />
  <link rel="stylesheet" href="{{ '/assets/css/v2-print.css?v=' | append: asset_version | relative_url }}" media="print" />
  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-MCX316G25G"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-MCX316G25G');</script>
  <script src="{{ '/assets/js/v2-nav.js' | relative_url }}" defer></script>
</head>
<body class="v2-body">
  {% assign current_url = page.url | default: '' %}
  {% assign lang = page.lang | default: 'en' %}

  <header class="v2-topbar">
    <div class="v2-topbar__inner">
      {% if lang == 'zh' %}
      <a class="v2-topbar__brand" href="{{ '/zh/' | relative_url }}">Li Lab</a>
      {% else %}
      <a class="v2-topbar__brand" href="{{ '/' | relative_url }}">Li Lab</a>
      {% endif %}
      <button class="v2-topbar__toggle" aria-label="Toggle navigation" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
      <nav class="v2-topbar__nav">
        {% if lang == 'zh' %}
        <a href="{{ '/zh/projects/' | relative_url }}">科研方向</a>
        <a href="{{ '/zh/publications/' | relative_url }}">论文发表</a>
        <a href="{{ '/zh/team/' | relative_url }}">团队成员</a>
        <a href="{{ '/zh/clinical/' | relative_url }}">临床研究</a>
        <a href="{{ '/zh/contact/' | relative_url }}">联系我们</a>
        <a href="{{ '/' | relative_url }}">English</a>
        {% else %}
        <a href="{{ '/projects/' | relative_url }}">Research</a>
        <a href="{{ '/publications/' | relative_url }}">Publications</a>
        <a href="{{ '/team/' | relative_url }}">Team</a>
        <a href="{{ '/clinical/' | relative_url }}">Clinical</a>
        <a href="{{ '/contact/' | relative_url }}">Contact</a>
        <a href="{{ '/zh/' | relative_url }}">中文</a>
        {% endif %}
      </nav>
    </div>
  </header>

  <main>
    {{ content }}
  </main>

  <footer class="v2-site-footer">
    <div class="v2-site-footer__inner">
      <div class="v2-site-footer__logos">
        <img src="{{ '/assets/img/logos/csu.png' | relative_url }}" alt="Central South University">
        <img src="{{ '/assets/img/logos/xiangya.png' | relative_url }}" alt="Xiangya Hospital">
        <img src="{{ '/assets/img/logos/aging_lab.png' | relative_url }}" alt="Li Lab">
      </div>
      {% if lang == 'zh' %}
      <p>&copy; {{ 'now' | date: "%Y" }} Li Lab &middot; 中南大学湘雅医院</p>
      {% else %}
      <p>&copy; {{ 'now' | date: "%Y" }} Li Lab &middot; Xiangya Hospital, Central South University</p>
      {% endif %}
    </div>
  </footer>

  <button class="v2-back-top" aria-label="Back to top"><i class="fas fa-chevron-up"></i></button>
  <script>
  (function(){var b=document.querySelector('.v2-back-top');if(!b)return;window.addEventListener('scroll',function(){b.classList.toggle('is-visible',window.scrollY>300)},{passive:true});b.addEventListener('click',function(){window.scrollTo({top:0,behavior:'smooth'})})})();
  </script>
</body>
</html>
