---
layout: default
---
{% assign lang = page.lang | default: 'en' %}
{% assign t = site.data.i18n[lang] %}

<!-- Page Header -->
<div class="lab-section lab-page-header">
  <h2 class="lab-section__heading">{{ t.people.page_title }}</h2>
  <p class="lab-page-header__desc">{{ t.people.page_desc }}</p>
</div>

<!-- PI Section -->
{% assign pi = site.data.members | where: 'role', 'pi' %}
{% if pi.size > 0 %}
  <div class="lab-section lab-section--alt">
    <h3 class="lab-people__category">{{ t.people.pi }}</h3>
    {% for member in pi %}
      <div class="lab-pi-card">
        <div class="lab-pi-card__photo">
          <img src="{{ member.photo | relative_url }}" alt="{{ member.name }}" loading="lazy">
        </div>
        <div class="lab-pi-card__info">
          <h2 class="lab-pi-card__name">
            {% if lang == 'zh' %}
              {{ member.name }}
              <span class="lab-pi-card__name-en">{{ member.name_en }}</span>
            {% else %}
              {{ member.name_en }}
              <span class="lab-pi-card__name-en">{{ member.name }}</span>
            {% endif %}
          </h2>
          <p class="lab-pi-card__title">
            {% if lang == 'zh' %}{{ member.title }}{% else %}{{ member.title_en }}{% endif %}
          </p>
          <p class="lab-pi-card__bio">
            {% if lang == 'zh' %}{{ member.bio_zh | default: member.bio }}{% else %}{{ member.bio }}{% endif %}
          </p>
          <div class="lab-pi-card__links">
            {% if member.email %}
              <a href="mailto:{{ member.email }}" title="Email"><i class="fas fa-envelope"></i></a>
            {% endif %}
            {% if member.scholar %}
              <a href="https://scholar.google.com/citations?user={{ member.scholar }}" target="_blank" title="Google Scholar"
                ><i class="ai ai-google-scholar"></i
              ></a>
            {% endif %}
            {% if member.orcid %}
              <a href="https://orcid.org/{{ member.orcid }}" target="_blank" title="ORCID"><i class="ai ai-orcid"></i></a>
            {% endif %}
            {% if member.researchgate %}
              <a href="https://www.researchgate.net/profile/{{ member.researchgate }}" target="_blank" title="ResearchGate"
                ><i class="ai ai-researchgate"></i
              ></a>
            {% endif %}
            {% if member.github %}
              <a href="https://github.com/{{ member.github }}" target="_blank" title="GitHub"><i class="fab fa-github"></i></a>
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
{% endif %}

<!-- Faculty -->
{% assign faculty = site.data.members | where: 'role', 'faculty' %}
{% if faculty.size > 0 %}
  <div class="lab-section">
    <h3 class="lab-people__category">{{ t.people.faculty }}</h3>
    <div class="lab-people-grid">
      {% for member in faculty %}
        <div class="lab-member-card">
          <div class="lab-member-card__photo">
            <img src="{{ member.photo | relative_url }}" alt="{{ member.name }}" loading="lazy">
          </div>
          <div class="lab-member-card__body">
            <h4 class="lab-member-card__name">
              {% if lang == 'zh' %}
                {{ member.name }}
                <span class="lab-member-card__name-en">{{ member.name_en }}</span>
              {% else %}
                {{ member.name_en }}
                <span class="lab-member-card__name-en">{{ member.name }}</span>
              {% endif %}
            </h4>
            <p class="lab-member-card__title">
              {% if lang == 'zh' %}{{ member.title }}{% else %}{{ member.title_en }}{% endif %}
            </p>
            <p class="lab-member-card__dept">
              {% if lang == 'zh' %}{{ member.department }}{% else %}{{ member.department_en | default: member.department }}{% endif %}
            </p>
            <p class="lab-member-card__bio">
              {% if lang == 'zh' %}{{ member.bio_zh | default: member.bio }}{% else %}{{ member.bio }}{% endif %}
            </p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
{% endif %}

