      {% for member in basic %}
        <div class="lab-member-card">
          <div class="lab-member-card__photo">
            <img src="{{ member.photo | relative_url }}" alt="{{ member.name }}" loading="lazy">
          </div>
          <div class="lab-member-card__body">
            <h4 class="lab-member-card__name">
              {% if lang == 'zh' %}
                {{ member.name }}
                <span class="lab-member-card__name-en">{{ member.name_en }}</span>
              {% else %}
                {{ member.name_en }}
                <span class="lab-member-card__name-en">{{ member.name }}</span>
              {% endif %}
            </h4>
            <p class="lab-member-card__title">
              {% if lang == 'zh' %}{{ member.title }}{% else %}{{ member.title_en }}{% endif %}
            </p>
            <p class="lab-member-card__bio">
              {% if lang == 'zh' %}{{ member.bio_zh | default: member.bio }}{% else %}{{ member.bio }}{% endif %}
            </p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
{% endif %}

